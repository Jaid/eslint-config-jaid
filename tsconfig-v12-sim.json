{
  "compilerOptions": {
    "allowArbitraryExtensions": true,
    "allowImportingTsExtensions": true,
    "composite": true,
    "module": "nodenext",
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "moduleResolution": "nodenext",
    "newLine": "lf",
    "skipLibCheck": true,
    "strictNullChecks": true,
    "allowJs": true,
    "target": "esnext",
    "experimentalDecorators": true,
    "noEmit": true,
    "inlineSourceMap": true,
    "outDir": "./out/ts",
    "lib": [
      "esnext"
    ],
    "jsx": "react",
    "types": [
      "node"
    ]
  },
  "typeAcquisition": {
    "enable": true
  },
  "include": [
    "./*",
    "./src/**/*",
    "./lib/**/*",
    "./test/**/*",
    "./scripts/**/*",
    "./etc/**/*"
  ]
}